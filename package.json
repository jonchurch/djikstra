{
  "name": "djikstra",
  "version": "0.1.1",
  "description": "A TypeScript implementation of Dijkstra's algorithm for finding shortest paths in graphs",
  "keywords": [
    "dijkstra",
    "pathfinding",
    "graph",
    "algorithm",
    "shortest path",
    "dijkstra's algorithm"
  ],
  "author": "jonchurch",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonchurch/djikstra.git"
  },
  "bugs": {
    "url": "https://github.com/jonchurch/djikstra/issues"
  },
  "homepage": "https://github.com/jonchurch/djikstra#readme",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
